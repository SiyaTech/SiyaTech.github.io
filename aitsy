    <!-- INTERACTIVE SCRIPTS (Reveal on scroll + Custom Sandbox Payload Simulator + Mouse spotlights) -->
    <script>
        // Smooth Intersection Observer Reveal Activator
        document.addEventListener("DOMContentLoaded", () => {
            const elements = document.querySelectorAll(".reveal-on-scroll");
            const observerOptions = {
                root: null,
                threshold: 0.05,
                rootMargin: "0px 0px -50px 0px"
            };

            const observer = new IntersectionObserver((entries, obs) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add("active");
                        // Once transition triggers, we can unobserve
                        obs.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            elements.forEach(el => observer.observe(el));

            // SCROLL BAR PROGRESS UPDATER
            window.addEventListener('scroll', () => {
                const totalHeight = document.documentElement.scrollHeight - window.innerHeight;
                const progress = totalHeight > 0 ? (window.pageYOffset / totalHeight) : 0;
                const bar = document.getElementById('etsy-scroll-bar');
                if (bar) {
                    bar.style.transform = `scaleX(${progress})`;
                }
            });

            // MOUSESPOT CARD GRADIENT COORDS
            const cards = document.querySelectorAll('.spotlight-card');
            cards.forEach(card => {
                card.addEventListener('mousemove', e => {
                    const rect = card.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    card.style.setProperty('--mouse-x', `${x}px`);
                    card.style.setProperty('--mouse-y', `${y}px`);
                });
            });

            // CURSOR FOLLOW FLUID GLOW
            const cursorGlow = document.getElementById('etsy-cursor-glow');
            if (cursorGlow) {
                document.addEventListener('mousemove', e => {
                    cursorGlow.style.opacity = "1";
                    cursorGlow.style.left = e.clientX + 'px';
                    cursorGlow.style.top = e.clientY + 'px';
                });
                
                document.addEventListener('mouseleave', () => {
                    cursorGlow.style.opacity = "0";
                });
            }

            // Setup dynamic live ticking clock
            setInterval(() => {
                const now = new Date();
                const cleanStr = now.getUTCFullYear() + "-" + 
                    String(now.getUTCMonth() + 1).padStart(2, '0') + "-" + 
                    String(now.getUTCDate()).padStart(2, '0') + " " + 
                    String(now.getUTCHours()).padStart(2, '0') + ":" + 
                    String(now.getUTCMinutes()).padStart(2, '0') + ":" + 
                    String(now.getUTCSeconds()).padStart(2, '0') + " UTC";
                const timeEl = document.getElementById("ticker-time");
                if (timeEl) timeEl.textContent = cleanStr;
            }, 1000);
        });

        // Live Dynamic Sandbox compliance generator
        function updatePayloadSim() {
            const usePrefix = document.getElementById("sim-prefix").checked;
            const lowPrice = document.getElementById("sim-price").checked;

            const codeBlock = document.getElementById("simulation-code-block");

            const finalTitle = usePrefix 
                ? "[TEST] Custom Leather Stamped Wallet Pipeline SKU-101" 
                : "Custom Leather Stamped Wallet Pipeline SKU-101";

            const finalDesc = usePrefix 
                ? "[TEST] Handcrafted physical coordinates detailing raw production steps...\n\n--- COMPLIANCE NOTE: Created via Etsy API Test Pipeline in Draft sandbox state." 
                : "Handcrafted physical coordinates detailing raw production steps for handmade inventory tracking.";

            const finalPrice = lowPrice ? 0.20 : 34.99;

            const mockObj = {
                title: finalTitle,
                description: finalDesc,
                price: parseFloat(finalPrice.toFixed(2)),
                state: "draft",
                materials: [
                    "Full-Grain Veg-Tan Leather", 
                    "Waxed Linen Cord", 
                    "Beeswax Finish"
                ],
                taxonomy_id: 1390,
                quantity: 1,
                who_made: "i_did",
                is_writeable: true,
                developer_compliance_toggles: {
                    sandbox_security_strict: true,
                    user_email: "developer@taxware.in",
                    test_flag_attached: usePrefix,
                    safeguard_low_price: lowPrice
                }
            };

            if (codeBlock) {
                codeBlock.textContent = JSON.stringify(mockObj, null, 2);
            }
        }
    </script>

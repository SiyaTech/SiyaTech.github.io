        /* Ambient Glow Vectors */
        .quantum-mesh {
            background-image: 
                radial-gradient(at 0% 0%, rgba(168, 85, 247, 0.12) 0px, transparent 50%),
                radial-gradient(at 100% 0%, rgba(6, 182, 212, 0.12) 0px, transparent 50%),
                radial-gradient(at 50% 50%, rgba(241, 100, 30, 0.04) 0px, transparent 70%);
        }

        /* Antigravity floating simulation keyframe */
        @keyframes float {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-12px) rotate(0.8deg); }
        }
        @keyframes float-delayed {
            0%, 100% { transform: translateY(0px) rotate(0deg); }
            50% { transform: translateY(-8px) rotate(-0.5deg); }
        }
        @keyframes pulse-ring {
            0% { transform: scale(0.95); opacity: 0.2; }
            50% { transform: scale(1.05); opacity: 0.5; }
            100% { transform: scale(0.95); opacity: 0.2; }
        }

        .element-float {
            animation: float 7s ease-in-out infinite;
        }
        .element-float-delay {
            animation: float-delayed 9s ease-in-out infinite;
        }

        /* Radial Spotlight Background Hover Technique with dynamic pointer coordinates */
        .spotlight-card {
            position: relative;
            background: rgba(15, 15, 25, 0.65);
            border: 1px solid rgba(255, 255, 255, 0.04);
            transition: border-color 0.4s, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s;
            overflow: hidden;
        }
        .spotlight-card::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(350px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(168, 85, 247, 0.15), transparent 50%);
            z-index: 1;
            pointer-events: none;
            opacity: 0;
            transition: opacity 0.4s;
        }
        .spotlight-card:hover::before {
            opacity: 1;
        }
        .spotlight-card:hover {
            border-color: rgba(168, 85, 247, 0.35);
            box-shadow: 0 10px 30px -10px rgba(168, 85, 247, 0.2);
            transform: translateY(-4px);
        }

        /* Fixed Active Floating Cursor Glow Element */
        #etsy-cursor-glow {
            position: fixed;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: radial-gradient(circle, rgba(168, 85, 247, 0.04) 0%, rgba(6, 182, 212, 0.02) 40%, transparent 70%);
            pointer-events: none;
            z-index: 2;
            transform: translate(-50%, -50%);
            transition: transform 0.1s ease-out;
            opacity: 0;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 10px;
        }
        ::-webkit-scrollbar-track {
            background: #020205;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(168, 85, 247, 0.25);
            border: 2px solid #020205;
            border-radius: 5px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(168, 85, 247, 0.5);
        }

        /* Intersection Fade */
        .reveal-on-scroll {
            opacity: 0;
            transform: translateY(30px) scale(0.97);
            filter: blur(4px);
            transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), 
                        transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
                        filter 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            will-change: transform, opacity;
        }
        .reveal-on-scroll.active {
            opacity: 1;
            transform: translateY(0) scale(1);
            filter: blur(0);
        }
    </style>
